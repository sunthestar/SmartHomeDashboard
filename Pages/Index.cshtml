@page
@model IndexModel
@{
    ViewData["Title"] = "智能家居后台监控系统";
}

<!-- 头部：包含标题、天气、日期、实时时间、登录图标和日夜切换 -->
<div class="header">
    <div class="header-left">
        <h1>家居中枢 · 智慧后台</h1>
        <div class="greeting">
            <i class="fas fa-circle dot"></i> 系统在线 · 所有设备通信正常
            <span style="margin-left: 16px;"><i class="far fa-bell" style="color: #3f8bcb;"></i> 3条警报</span>
        </div>
    </div>
    <div class="header-right">
        <div class="weather" id="weatherWidget">
            <div class="weather-icon-large">
                <i class="fas fa-cloud-sun" id="weatherIcon"></i>
            </div>
            <div class="weather-info">
                <div class="weather-temp" id="weatherTemp">--°C</div>
                <div class="weather-desc" id="weatherDesc">正在获取天气...</div>
                <div class="weather-detail">
                    <span class="weather-humidity"><i class="fas fa-tint"></i> <span id="humidityValue">--</span>%</span>
                    <span class="weather-separator">·</span>
                    <span class="weather-city"><i class="fas fa-map-marker-alt"></i> <span id="cityName">定位中...</span></span>
                </div>
            </div>
        </div>
        <div class="date-badge" id="datetimeDisplay">
            <i class="far fa-calendar-alt"></i>
            <span id="datePart">@DateTime.Now.ToString("yyyy-MM-dd dddd")</span>
            <span id="timePart" style="margin-left: 8px; font-family: monospace;">@DateTime.Now.ToString("HH:mm:ss")</span>
        </div>
        <!-- 登录图标 + 日夜切换按钮 -->
        <div class="action-icons">
            <a href="/Login?handler=logout" style="text-decoration: none; color: inherit;" onclick="return confirm('确定要退出登录吗？');">
                <i class="fas fa-sign-out-alt login-icon" title="退出登录"></i>
            </a>
            <div class="theme-toggle" id="themeToggleBtn">
                <i class="fas fa-sun"></i>
                <i class="fas fa-moon night-icon"></i>
                <div class="toggle-ball"></div>
            </div>
        </div>
    </div>
</div>

<!-- KPI 卡片行 -->
<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-icon"><i class="fas fa-bolt"></i></div>
        <div class="kpi-content">
            <h3>实时功率</h3>
            <div class="kpi-main">
                <span class="value" id="realTimePower">0.00</span><span class="unit">kW</span>
                <span class="trend" id="powerTrend"><i class="fas fa-minus"></i> 0%</span>
            </div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon"><i class="fas fa-tint"></i></div>
        <div class="kpi-content">
            <h3>平均湿度</h3>
            <div class="kpi-main">
                <span class="value" id="averageHumidity">--</span><span class="unit">%</span>
            </div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon"><i class="fas fa-temperature-low"></i></div>
        <div class="kpi-content">
            <h3>平均室温</h3>
            <div class="kpi-main">
                <span class="value" id="averageRoomTemp">--</span><span class="unit">°C</span>
            </div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon"><i class="fas fa-shield-alt"></i></div>
        <div class="kpi-content">
            <h3>安全设备</h3>
            <div class="kpi-main">
                <span class="value" id="securityDevices">@Model.SecurityDevices</span><span class="unit">在线</span>
            </div>
        </div>
    </div>
</div>

<!-- 主区域: 左侧设备 + 右侧能耗监控 -->
<div class="main-panels">
    <!-- 左侧设备部分 -->
    <div class="device-section">
        <div class="section-header">
            <h2><i class="fas fa-microchip"></i> 智能设备 · 房间一览</h2>
            <div class="badge" id="onlineDevicesCount">@Model.OnlineDevices 台在线</div>
        </div>
        <!-- 房间标签 -->
        <div class="room-tabs">
            <div class="room-tab active" data-room="all"><i class="fas fa-home"></i> 全部</div>
            <div class="room-tab" data-room="living"><i class="fas fa-couch"></i> 客厅</div>
            <div class="room-tab" data-room="master-bedroom"><i class="fas fa-bed"></i> 主卧</div>
            <div class="room-tab" data-room="second-bedroom"><i class="fas fa-bed"></i> 次卧</div>
            <div class="room-tab" data-room="kitchen"><i class="fas fa-kitchen-set"></i> 厨房</div>
            <div class="room-tab" data-room="bathroom"><i class="fas fa-bath"></i> 浴室</div>
            <div class="room-tab" data-room="dining"><i class="fas fa-utensils"></i> 餐厅</div>
            <div class="room-tab" data-room="entrance"><i class="fas fa-door-open"></i> 入口</div>
        </div>

        <div class="device-grid" id="deviceGrid">
            @foreach (var device in Model.Devices)
            {
                var isOffline = !device.IsOn && device.StatusText == "离线";
                <div class="device-item @(isOffline ? "offline" : "")" data-id="@device.Id" data-room="@device.Room" data-type="@device.Type" data-power="@device.PowerValue" style="cursor: pointer;" title="点击设置">
                    <div class="device-row">
                        <div class="device-name">
                            <i class="fas @device.Icon"></i>
                            <span>@device.Name</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                            <div class="device-status @(device.IsOn && device.StatusText != "离线" ? "on" : "")"
                                 data-device-type="@device.Type"
                                 data-is-on="@(device.IsOn.ToString().ToLower())"
                                 data-temperature="@device.Temperature"
                                 data-humidity="@device.Humidity"
                                 data-speed="@device.MotorSpeed"
                                 data-mode="@device.Mode"
                                 data-direction="@device.Direction"
                                 data-swing-vertical="@(device.SwingVertical?.ToString().ToLower() ?? "false")"
                                 data-swing-horizontal="@(device.SwingHorizontal?.ToString().ToLower() ?? "false")"
                                 data-light="@(device.Light?.ToString().ToLower() ?? "false")"
                                 data-quiet="@(device.Quiet?.ToString().ToLower() ?? "false")">
                                @if (device.IsOn && device.StatusText != "离线")
                                {
                                    <i class="fas fa-circle" style="font-size:0.5rem; margin-right:5px; color:#2ecc71;"></i>
                                }
                                @if (device.StatusText == "离线")
                                {
                                    <i class="fas fa-power-off" style="font-size:0.8rem; margin-right:5px; color:#ff6b6b;"></i>
                                }
                                <span class="status-text">
                                    @{
                                        if (device.StatusText == "离线")
                                        {
                                            @:离线
                                        }
                                        else
                                        {
                                            switch (device.Type)
                                            {
                                                case "lock":
                                                    @(device.IsOn ? "已上锁" : "未上锁")
                                                    break;
                                                case "ac":
                                                    if (device.IsOn)
                                                    {
                                                        var modeText = device.Mode switch
                                                        {
                                                            "cool" => "制冷",
                                                            "heat" => "制热",
                                                            "fan" => "送风",
                                                            "dry" => "除湿",
                                                            "auto" => "自动",
                                                            _ => device.Mode ?? "制冷"
                                                        };
                                                        @:@(modeText) @(device.Temperature?.ToString("F0") ?? "24")°C
                                                    }
                                                    else
                                                    {
                                                        @:关闭
                                                    }
                                                    break;
                                                case "temp-sensor":
                                                    if (device.Temperature.HasValue)
                                                    {
                                                        @:温度 @device.Temperature.Value.ToString("F1")°C
                                                    }
                                                    else
                                                    {
                                                        @:在线
                                                    }
                                                    break;
                                                case "humidity-sensor":
                                                    if (device.Humidity.HasValue)
                                                    {
                                                        @:湿度 @device.Humidity%
                                                    }
                                                    else
                                                    {
                                                        @:在线
                                                    }
                                                    break;
                                                case "fan":
                                                    if (device.IsOn)
                                                    {
                                                        if (device.MotorSpeed.HasValue)
                                                        {
                                                            @:风速 @(device.MotorSpeed)档
                                                        }
                                                        else
                                                        {
                                                            @:运行中
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @:关闭
                                                    }
                                                    break;
                                                case "motor":
                                                    if (device.IsOn)
                                                    {
                                                        @:电机 @(device.Direction == "forward" ? "正转" : device.Direction == "reverse" ? "反转" : "停止")
                                                    }
                                                    else
                                                    {
                                                        @:停止
                                                    }
                                                    break;
                                                case "light":
                                                    @(device.IsOn ? "开启" : "关闭")
                                                    break;
                                                case "camera":
                                                    @(device.IsOn ? "在线" : "离线")
                                                    break;
                                                default:
                                                    @device.StatusText
                                                    break;
                                            }
                                        }
                                    }
                                </span>
                            </div>
                            <i class="fas fa-trash-alt delete-device" style="color: #ff6b6b; cursor: pointer; font-size: 1rem;" title="删除设备"></i>
                        </div>
                    </div>
                    <div class="device-detail">
                        <span class="device-detail-text">
                            @{
                                if (device.StatusText == "离线")
                                {
                                    @:最后在线: 刚刚
                                }
                                else
                                {
                                    switch (device.Type)
                                    {
                                        case "lock":
                                            if (device.Humidity.HasValue)
                                            {
                                                @:电量 @device.Humidity%
                                            }
                                            else
                                            {
                                                @device.Detail
                                            }
                                            break;
                                        case "ac":
                                            var modeDisplay = device.Mode switch
                                            {
                                                                        "cool" => "制冷",
                                                                        "heat" => "制热",
                                                                        "fan" => "送风",
                                                                        "dry" => "除湿",
                                                                        "auto" => "自动",
                                                _ => device.Mode ?? "制冷"
                                            };
                                            @:模式: @modeDisplay · @(device.Temperature?.ToString("F0") ?? "23")°C · 风速中
                                            break;
                                        case "temp-sensor":
                                            @:温度传感器 · 在线
                                            break;
                                        case "humidity-sensor":
                                            @:湿度传感器 · 在线
                                            break;
                                        case "fan":
                                            @:风扇 @(device.IsOn ? "运行中" : "已关闭")
                                            break;
                                        case "motor":
                                            @:电机 @(device.IsOn ? "运行中" : "已停止")
                                            break;
                                        case "light":
                                            @:亮度 @(device.Progress)%
                                            break;
                                        case "camera":
                                            @:事件 2
                                            break;
                                        default:
                                            @device.Detail
                                            break;
                                    }
                                }
                            }
                        </span>
                        <span class="device-power" data-power-value="@device.PowerValue">
                            @if (device.Type == "lock" || device.Type == "camera" || device.Type == "temp-sensor" || device.Type == "humidity-sensor")
                            {
                                if (device.Humidity.HasValue)
                                {
                                    var batteryLevel = device.Humidity.Value;
                                    var batteryIcon = batteryLevel >= 75 ? "fa-battery-full" :
                                    batteryLevel >= 50 ? "fa-battery-three-quarters" :
                                    batteryLevel >= 25 ? "fa-battery-half" :
                                    batteryLevel >= 10 ? "fa-battery-quarter" : "fa-battery-empty";
                                    var batteryColor = batteryLevel <= 15 ? "#f44336" :
                                    batteryLevel <= 30 ? "#ff9800" : "#4caf50";
                                    <i class="fas @batteryIcon" style="color: @batteryColor;" title="电量 @device.Humidity%"></i>
                                }
                                else
                                {
                                    @device.Power
                                }
                            }
                            else
                            {
                                @device.Power
                            }
                        </span>
                    </div>
                    <div class="progress-bg">
                        <div class="progress-fill" style="width: @(device.Progress)%@(device.ProgressColor != null ? "; background:" + device.ProgressColor : "")"></div>
                    </div>
                </div>
            }
        </div>
        <hr>
        <!-- 按键式按钮区域 -->
        <div style="display: flex; gap: 15px; margin-top: 15px; margin-bottom: 20px;">
            <!-- 添加设备按键 -->
            <button class="action-button add-button" id="addDeviceBtn">
                <i class="fas fa-plus-circle"></i>
                <span>添加设备</span>
            </button>

            <!-- 所有日志按键 -->
            <button class="action-button log-button" id="logsBtn">
                <i class="fas fa-scroll"></i>
                <span>所有日志</span>
            </button>
        </div>

        <!-- 最新日志区域 - 显示4条 -->
        <div class="recent-logs-container">
            <div class="recent-logs-header">
                <i class="fas fa-history"></i>
                <span>最新动态</span>
            </div>
            <div class="recent-logs-list" id="recentLogsList">
                <!-- 日志将通过JavaScript动态加载 -->
            </div>
        </div>
    </div>

    <!-- 右侧面板 -->
    <div class="right-panel">
        <!-- 能耗卡 -->
        <div class="energy-card">
            <div class="energy-header">
                <h3><i class="fas fa-chart-line" style="color:#f09b42;"></i> 今日能耗趋势</h3>
                <span style="color:#4d7cb3;" id="energyComparison">与昨日 +4%</span>
            </div>
            <div class="energy-value" id="totalEnergy">@Model.TotalEnergy kWh</div>
            <div class="energy-sub">
                <span id="estimatedEnergy">预估 @Model.EstimatedEnergy kWh</span>
                <span id="peakPower">峰值 @Model.PeakPower kW (14:30)</span>
            </div>

            <!-- 柱状图 -->
            <div class="energy-graph" id="energyGraph">
                @foreach (var value in Model.EnergyData)
                {
                    <div class="graph-bar"><div class="fill" style="height: @value%;"></div></div>
                }
            </div>

            <div style="display:flex; justify-content:space-between; color:#53779e; font-size:0.8rem; margin-top:6px;">
                <span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>现在</span>
            </div>
        </div>

        <!-- 实时监控卡 -->
        <div class="camera-card">
            <div class="section-header" style="margin-bottom:8px;">
                <h2 style="font-size:1.2rem;"><i class="fas fa-video"></i> 实时监控</h2>
                <span class="badge">@Model.CameraCount 个画面</span>
            </div>
            @foreach (var camera in Model.Cameras)
            {
                <div class="camera-feed">
                    <div class="feed-thumb"><i class="fas @camera.Icon"></i></div>
                    <div class="feed-info">
                        <p>
                            @camera.Name
                            @if (camera.HasMotion)
                            {
                                <span class="motion-tag"><i class="fas fa-running"></i> 移动侦测</span>
                            }
                        </p>
                        <p class="time"><i class="far fa-clock"></i> @camera.TimeText</p>
                        @if (!string.IsNullOrEmpty(camera.Status))
                        {
                            <p style="color:#1d4c7c; margin-top:6px;">@camera.Status</p>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- 自动化卡 -->
        <div class="automation-card">
            <div class="section-header" style="margin-bottom:8px;">
                <h2 style="font-size:1.2rem;"><i class="fas fa-clock"></i> 智能自动化</h2>
                <span class="badge" id="activeScenesCount">0 执行中</span>
            </div>
            <div class="scene-list" id="sceneList">
                @foreach (var scene in Model.Scenes)
                {
                    <div class="scene-item" data-scene-id="@scene.Id" data-scene-name="@scene.Name">
                        <div class="scene-left">
                            <i class="fas @scene.Icon"></i>
                            <span>@scene.Name</span>
                        </div>
                        <div class="toggle-switch @(scene.IsActive ? "active" : "inactive")" data-scene-id="@scene.Id"></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- 添加设备模态框 -->
<div id="addDeviceModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-plus-circle" style="color:#3f98f0;"></i> 添加新设备</h3>
            <span class="close-modal">&times;</span>
        </div>
        <div class="modal-body">
            <form id="addDeviceForm">
                <div class="form-group">
                    <label for="deviceName">设备名称</label>
                    <input type="text" id="deviceName" name="deviceName" required placeholder="例如：客厅温度传感器">
                </div>
                <div class="form-group">
                    <label for="deviceRoom">所在房间</label>
                    <select id="deviceRoom" name="deviceRoom" required>
                        <option value="living">客厅</option>
                        <option value="master-bedroom">主卧</option>
                        <option value="second-bedroom">次卧</option>
                        <option value="kitchen">厨房</option>
                        <option value="bathroom">浴室</option>
                        <option value="dining">餐厅</option>
                        <option value="entrance">入口</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="deviceType">设备类型</label>
                    <select id="deviceType" name="deviceType" required>
                        <option value="light">💡 灯泡</option>
                        <option value="ac">❄️ 空调</option>
                        <option value="lock">🔒 门锁</option>
                        <option value="camera">📹 摄像头</option>
                        <option value="fan">🌀 风扇</option>
                        <option value="temp-sensor">🌡️ 温度传感器</option>
                        <option value="humidity-sensor">💧 湿度传感器</option>
                        <option value="motor">⚙️ 电机</option>
                    </select>
                </div>
                <div class="form-group" id="sensorTempGroup" style="display: none;">
                    <label for="sensorTemperature">当前温度 (°C)</label>
                    <input type="number" id="sensorTemperature" name="sensorTemperature" step="0.1" min="-50" max="100" value="22.0" placeholder="例如：22.5">
                </div>
                <div class="form-group" id="sensorHumidityGroup" style="display: none;">
                    <label for="sensorHumidity">当前湿度 (%)</label>
                    <input type="number" id="sensorHumidity" name="sensorHumidity" step="1" min="0" max="100" value="50" placeholder="例如：60">
                </div>
                <div class="form-group" id="motorSpeedGroup" style="display: none;">
                    <label for="motorSpeed">当前转速 (rpm)</label>
                    <input type="number" id="motorSpeed" name="motorSpeed" step="10" min="0" max="3000" value="1000" placeholder="例如：1200">
                </div>
                <div class="form-group">
                    <label for="devicePower">功率 (W/kW)</label>
                    <input type="text" id="devicePower" name="devicePower" required placeholder="例如：45W 或 1.2kW">
                </div>
                <div class="form-group">
                    <label for="deviceStatus">初始状态</label>
                    <select id="deviceStatus" name="deviceStatus" required>
                        <option value="on">开启</option>
                        <option value="off">关闭/待机</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="deviceProgress">进度百分比 (0-100)</label>
                    <input type="number" id="deviceProgress" name="deviceProgress" min="0" max="100" value="50" required>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary close-modal">取消</button>
            <button class="btn btn-primary" id="saveDeviceBtn">保存设备</button>
        </div>
    </div>
</div>

<!-- 设备设置模态框 - 不同类型有不同的界面 -->
<div id="deviceSettingsModal" class="modal" style="display: none;">
    <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
            <h3><i class="fas fa-cog"></i> <span id="settingsDeviceName">设备设置</span></h3>
            <span class="close-modal">&times;</span>
        </div>
        <div class="modal-body" id="settingsContent">
            <!-- 设置内容将通过JavaScript动态加载 -->
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary close-modal">关闭</button>
            <button class="btn btn-primary" id="saveSettingsBtn">保存设置</button>
        </div>
    </div>
</div>

<!-- 灯泡设置模板 -->
<template id="lightSettingsTemplate">
    <div class="settings-form">
        <div class="form-group">
            <label>开关</label>
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="toggle-switch active" id="lightPowerToggle"></div>
                <span id="lightPowerStatus">开启</span>
            </div>
        </div>
        <div class="form-group">
            <label>亮度</label>
            <input type="range" min="0" max="100" value="80" class="settings-input" id="lightBrightness">
            <span id="brightnessValue">80%</span>
        </div>
        <div class="form-group">
            <label>色温</label>
            <select class="settings-input" id="lightColorTemp">
                <option value="2700">暖光 (2700K)</option>
                <option value="4000">中性光 (4000K)</option>
                <option value="6500">冷光 (6500K)</option>
            </select>
        </div>
        <div class="form-group">
            <label>定时关闭</label>
            <input type="time" class="settings-input" id="lightTimer">
        </div>
    </div>
</template>

<!-- 空调设置模板 -->
<template id="acSettingsTemplate">
    <div class="settings-form">
        <div class="form-group">
            <label>开关</label>
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="toggle-switch active" id="acPowerToggle"></div>
                <span id="acPowerStatus">开启</span>
            </div>
        </div>
        <div class="form-group">
            <label>模式</label>
            <select class="settings-input" id="acMode">
                <option value="cool">制冷</option>
                <option value="heat">制热</option>
                <option value="fan">送风</option>
                <option value="dry">除湿</option>
                <option value="auto">自动</option>
            </select>
        </div>
        <div class="form-group">
            <label>温度</label>
            <input type="range" min="16" max="30" value="24" class="settings-input" id="acTemperature">
            <span id="tempValue">24°C</span>
        </div>
        <div class="form-group">
            <label>风速</label>
            <select class="settings-input" id="acFanSpeed">
                <option value="low">低风</option>
                <option value="medium" selected>中风</option>
                <option value="high">高风</option>
                <option value="auto">自动</option>
            </select>

        // ==================== 设备卡片点击事件 ====================
        function initDeviceCardClick() {
            document.querySelectorAll('.device-item').forEach(card => {
                card.addEventListener('click', function(e) {
                    if (e.target.closest('.delete-device')) return;
                    if (this.classList.contains('offline')) {
                        showNotification('设备已离线，无法设置', 'warning');
                        return;
                    }

                    const deviceId = this.dataset.id;
                    const deviceName = this.querySelector('.device-name span').textContent;
                    const deviceType = this.dataset.type;

                    openDeviceSettings(deviceId, deviceName, deviceType);
                });

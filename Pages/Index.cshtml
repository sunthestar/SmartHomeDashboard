        // 发送命令到设备
        function sendDeviceCommand(deviceId, command, parameters) {
            console.log(`发送命令到设备 ${deviceId}: ${command}`, parameters);

            fetch(`/api/tcp/devices/${deviceId}/command`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    command: command,
                    parameters: parameters
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('命令已发送', 'info');
                } else {
                    showNotification('命令发送失败: ' + data.message, 'error');
                }
            })
            .catch(error => {
                console.error('发送命令失败:', error);
                showNotification('发送命令失败', 'error');
            });
        }


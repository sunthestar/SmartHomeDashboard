@section Scripts {
    <script>
        // ==================== 全局变量 ====================
        let systemLogs = [];
        let powerHistory = [];
        let currentDeviceSettings = null;
        let signalRConnection = null;

        // ==================== 页面初始化 ====================
        document.addEventListener('DOMContentLoaded', function() {
            // 获取天气数据
            getWeatherData();

            // 加载自动化场景状态
            loadAutomationStates();

            // 计算实时功率
            calculateTotalPower();

            // 计算平均室温
            calculateAverageRoomTemp();

            // 计算平均湿度
            calculateAverageHumidity();

            // 实时时间更新
            updateDateTime();
            setInterval(updateDateTime, 1000);

            // 每30秒重新计算一次功率、室温和湿度
            setInterval(() => {
                calculateTotalPower();
                calculateAverageRoomTemp();
                calculateAverageHumidity();
            }, 30000);

            // 自动夜间模式检测
            checkAndApplyAutoNightMode();
            setInterval(checkAndApplyAutoNightMode, 60000);

            // 初始化各个功能模块
            initRoomTabs();
            initModal();
            initSaveDevice();
            initDeleteDevice();
            initThemeToggle();
            initLogs();
            initAutomationToggles();
            initDeviceCardClick();
            initDeviceTypeSelect();
            initSignalR();

            // 初始更新统计
            updateDeviceStats();
        });

        // ==================== SignalR 实时通信 ====================
        function initSignalR() {
            signalRConnection = new signalR.HubConnectionBuilder()
                .withUrl("/deviceHub")
                .withAutomaticReconnect()
                .configureLogging(signalR.LogLevel.Information)
                .build();

            // 设备列表更新 - 不再刷新整个页面，而是增量更新
            signalRConnection.on("DevicesUpdated", (devices) => {
                console.log("收到设备列表更新:", devices);
                // 不再刷新整个页面，而是更新设备卡片
                updateDevicesIncremental(devices);
            });

            signalRConnection.on("TelemetryUpdated", (deviceId, telemetry) => {
                console.log(`设备 ${deviceId} 遥测数据更新:`, telemetry);

                const deviceCards = document.querySelectorAll('.device-item');
                let updatedCard = null;

                deviceCards.forEach(card => {
                    const deviceIdParts = deviceId.split('-');
                    if (deviceIdParts.length !== 3) return;

                    const typeAbbr = deviceIdParts[0];
                    const roomAbbr = deviceIdParts[1];

                    const roomMap = {
                        'bat': 'bathroom', 'liv': 'living', 'ent': 'entrance',
                        'kit': 'kitchen', 'mbd': 'master-bedroom', 'sbd': 'second-bedroom', 'din': 'dining'
                    };

                    const typeMap = {
                        'lock': 'lock', 'light': 'light', 'hum': 'humidity-sensor',
                        'temp': 'temp-sensor', 'ac': 'ac', 'cam': 'camera',
                        'fan': 'fan', 'motor': 'motor'
                    };

                    const targetRoom = roomMap[roomAbbr];
                    const targetType = typeMap[typeAbbr];

                    const cardRoom = card.dataset.room;
                    const cardType = card.dataset.type;

                    if (cardRoom === targetRoom && cardType === targetType) {
                        updatedCard = card;

                        if (telemetry.isOnline !== undefined) {
                            updateDeviceOnlineStatus(card, telemetry.isOnline);
                        }

                        if (telemetry.isOn !== undefined) {
                            updateDevicePowerStatus(card, telemetry.isOn);
                        }

                        if (telemetry.temperatureValue !== undefined) {
                            updateTemperatureDisplay(card, telemetry.temperatureValue);
                        } else if (telemetry.temperature !== undefined) {
                            updateTemperatureDisplay(card, telemetry.temperature);
                        }

                        if (telemetry.humidityValue !== undefined) {
                            updateHumidityDisplay(card, telemetry.humidityValue);
                        }

                        if (telemetry.speed !== undefined) {
                            updateFanSpeedDisplay(card, telemetry.speed);
                        }

                        if (telemetry.mode !== undefined) {
                            updateAcModeDisplay(card, telemetry.mode);
                        }

                        if (telemetry.direction !== undefined) {
                            updateMotorDirectionDisplay(card, telemetry.direction);
                        }

                        if (telemetry.batteryLevel !== undefined) {
                            updateBatteryDisplay(card, telemetry.batteryLevel);
                        }

                        if (telemetry.power !== undefined) {
                            updatePowerDisplay(card, telemetry.power);
                        }
                    }
                });

                if (updatedCard) {
                    console.log(`已更新设备卡片: ${updatedCard.querySelector('.device-name span').textContent}`);

                    calculateAverageHumidity();
                    calculateAverageRoomTemp();
                    calculateTotalPower();
                    updateDeviceStats();

                    // 添加日志但不刷新页面
                    const deviceName = updatedCard.querySelector('.device-name span').textContent;
                    if (telemetry.isOnline !== undefined) {
                        addDeviceLog(deviceName, telemetry.isOnline ? '上线' : '离线', true);
                    }
                }
            });

            signalRConnection.start()
                .then(() => {
                    console.log("SignalR 连接成功");
                    showNotification('实时连接成功', 'success');
                })
                .catch(err => {
                    console.error("SignalR 连接失败:", err.toString());
                    showNotification('实时连接失败', 'error');
                });
        }

        // ==================== 增量更新设备列表 ====================
        function updateDevicesIncremental(devices) {
            console.log("增量更新设备列表:", devices);

            // 获取当前页面的所有设备卡片
            const currentCards = document.querySelectorAll('.device-item');
            const currentDeviceIds = new Set();

            currentCards.forEach(card => {
                currentDeviceIds.add(parseInt(card.dataset.id));
            });

            // 找出需要添加的新设备
            const newDevices = devices.filter(d => !currentDeviceIds.has(d.id));

            // 找出需要删除的设备
            const removedDeviceIds = Array.from(currentDeviceIds).filter(id =>
                !devices.some(d => d.id === id)
            );

            // 删除不存在的设备卡片
            removedDeviceIds.forEach(id => {
                const card = document.querySelector(`.device-item[data-id="${id}"]`);
                if (card) {
                    card.style.transition = 'all 0.3s ease';
                    card.style.opacity = '0';
                    card.style.transform = 'scale(0.8)';

                    setTimeout(() => {
                        if (card.parentNode) {
                            card.remove();
                            updateDeviceStats();
                            calculateTotalPower();
                            calculateAverageRoomTemp();
                            calculateAverageHumidity();
                        }
                    }, 300);
                }
            });

            // 添加新设备
            if (newDevices.length > 0) {
                console.log("检测到新设备:", newDevices);
                showNotification(`发现 ${newDevices.length} 个新设备，请刷新页面查看`, 'info');
            }

            // 更新现有设备的状态（不刷新页面）
            devices.forEach(device => {
                const card = document.querySelector(`.device-item[data-id="${device.id}"]`);
                if (card) {
                    // 更新数据属性
                    card.dataset.room = device.room;
                    card.dataset.type = device.type;
                    card.dataset.power = device.powerValue;

                    // 更新状态文本
                    const statusElement = card.querySelector('.device-status');
                    if (statusElement) {
                        statusElement.dataset.temperature = device.temperature;
                        statusElement.dataset.humidity = device.humidity;
                        statusElement.dataset.speed = device.motorSpeed;
                        statusElement.dataset.mode = device.mode;
                        statusElement.dataset.direction = device.direction;

                        // 更新开关状态
                        if (device.isOn && device.statusText !== "离线") {
                            statusElement.classList.add('on');
                            if (!statusElement.querySelector('.fa-circle')) {
                                const circle = document.createElement('i');
                                circle.className = 'fas fa-circle';
                                circle.style.cssText = 'font-size:0.5rem; margin-right:5px; color:#2ecc71;';
                                statusElement.insertBefore(circle, statusElement.firstChild);
                            }

                            // 移除离线图标
                            const offlineIcon = statusElement.querySelector('.fa-power-off');
                            if (offlineIcon) offlineIcon.remove();
                        } else {
                            statusElement.classList.remove('on');
                            const circle = statusElement.querySelector('.fa-circle');
                            if (circle) circle.remove();

                            if (device.statusText === "离线" && !statusElement.querySelector('.fa-power-off')) {
                                const offlineIcon = document.createElement('i');
                                offlineIcon.className = 'fas fa-power-off';
                                offlineIcon.style.cssText = 'font-size:0.8rem; margin-right:5px; color:#ff6b6b;';
                                statusElement.insertBefore(offlineIcon, statusElement.firstChild);
                            }
                        }

                        // 更新状态文本
                        const statusText = statusElement.querySelector('.status-text');
                        if (statusText) {
                            statusText.textContent = device.statusText;
                        }
                    }

                    // 更新详情文本
                    const detailText = card.querySelector('.device-detail-text');
                    if (detailText) {
                        detailText.textContent = device.detail;
                    }

                    // 更新功率/电量显示
                    const powerSpan = card.querySelector('.device-power');
                    if (powerSpan) {
                        powerSpan.dataset.powerValue = device.powerValue;

                        // 如果是电池设备，更新电池图标
                        if (device.type === 'lock' || device.type === 'camera' ||
                            device.type === 'temp-sensor' || device.type === 'humidity-sensor') {
                            if (device.humidity) {
                                const batteryLevel = device.humidity;
                                const batteryIcon = powerSpan.querySelector('.fa-battery-full, .fa-battery-three-quarters, .fa-battery-half, .fa-battery-quarter, .fa-battery-empty');

                                if (batteryIcon) {
                                    batteryIcon.className = batteryIcon.className.replace(/fa-battery-\w+/g, '');

                                    if (batteryLevel >= 75) {
                                        batteryIcon.classList.add('fa-battery-full');
                                    } else if (batteryLevel >= 50) {
                                        batteryIcon.classList.add('fa-battery-three-quarters');
                                    } else if (batteryLevel >= 25) {
                                        batteryIcon.classList.add('fa-battery-half');
                                    } else if (batteryLevel >= 10) {
                                        batteryIcon.classList.add('fa-battery-quarter');
                                    } else {
                                        batteryIcon.classList.add('fa-battery-empty');
                                    }

                                    if (batteryLevel <= 15) {
                                        batteryIcon.style.color = '#f44336';
                                    } else if (batteryLevel <= 30) {
                                        batteryIcon.style.color = '#ff9800';
                                    } else {
                                        batteryIcon.style.color = '#4caf50';
                                    }

                                    batteryIcon.title = `电量 ${batteryLevel}%`;
                                }
                            }
                        } else {
                            powerSpan.textContent = device.power;
                        }
                    }

                    // 更新进度条
                    const progressFill = card.querySelector('.progress-fill');
                    if (progressFill) {
                        progressFill.style.width = device.progress + '%';
                        if (device.progressColor) {
                            progressFill.style.background = device.progressColor;
                        }
                    }

                    // 更新离线状态
                    if (device.statusText === "离线") {
                        card.classList.add('offline');
                    } else {
                        card.classList.remove('offline');
                    }
                }
            });

            // 重新计算统计信息
            updateDeviceStats();
            calculateTotalPower();
            calculateAverageRoomTemp();
            calculateAverageHumidity();
        }

        // ==================== 设备状态更新函数 ====================

        // 获取模式文本
        function getModeText(mode) {
            switch(mode) {
                case 'cool': return '制冷';
                case 'heat': return '制热';
                case 'fan': return '送风';
                case 'dry': return '除湿';
                case 'auto': return '自动';
                default: return mode;
            }
        }

        // 更新设备开关状态
        function updateDevicePowerStatus(card, isOn) {
            const statusElement = card.querySelector('.device-status');
            const statusText = statusElement?.querySelector('.status-text');
            const deviceType = card.dataset.type;

            if (statusElement) {
                if (isOn) {
                    statusElement.classList.add('on');
                    if (!statusElement.querySelector('.fa-circle')) {
                        const circle = document.createElement('i');
                        circle.className = 'fas fa-circle';
                        circle.style.cssText = 'font-size:0.5rem; margin-right:5px; color:#2ecc71;';
                        statusElement.insertBefore(circle, statusElement.firstChild);
                    }
                } else {
                    statusElement.classList.remove('on');
                    const circle = statusElement.querySelector('.fa-circle');
                    if (circle) circle.remove();
                }

                statusElement.dataset.isOn = isOn;
            }

            if (statusText) {
                switch(deviceType) {
                    case 'lock':
                        statusText.textContent = isOn ? '已上锁' : '未上锁';
                        break;

                    case 'ac':
                        if (isOn) {
                            const mode = statusElement.dataset.mode || 'cool';
                            const temperature = statusElement.dataset.temperature || '23';
                            const modeText = getModeText(mode);
                            statusText.textContent = `${modeText} ${temperature}°C`;
                        } else {
                            statusText.textContent = '关闭';
                        }
                        break;

                    case 'temp-sensor':
                        if (isOn) {
                            const temperature = statusElement.dataset.temperature;
                            statusText.textContent = temperature ? `温度 ${parseFloat(temperature).toFixed(1)}°C` : '在线';
                        } else {
                            statusText.textContent = '离线';
                        }
                        break;

                    case 'humidity-sensor':
                        if (isOn) {
                            const humidity = statusElement.dataset.humidity;
                            statusText.textContent = humidity ? `湿度 ${humidity}%` : '在线';
                        } else {
                            statusText.textContent = '离线';
                        }
                        break;

                    case 'fan':
                        if (isOn) {
                            const speed = statusElement.dataset.speed;
                            statusText.textContent = speed ? `风速 ${speed}档` : '运行中';
                        } else {
                            statusText.textContent = '关闭';
                        }
                        break;

                    case 'motor':
                        if (isOn) {
                            const direction = statusElement.dataset.direction;
                            if (direction === 'forward') {
                                statusText.textContent = '正转';
                            } else if (direction === 'reverse') {
                                statusText.textContent = '反转';
                            } else {
                                statusText.textContent = '停止';
                            }
                        } else {
                            statusText.textContent = '停止';
                        }
                        break;

                    case 'light':
                        statusText.textContent = isOn ? '开启' : '关闭';
                        break;

                    case 'camera':
                        statusText.textContent = isOn ? '在线' : '离线';
                        break;

                    default:
                        statusText.textContent = isOn ? '开启' : '待机';
                        break;
                }
            }
        }

        // 更新温度显示
        function updateTemperatureDisplay(card, temperature) {
            const statusElement = card.querySelector('.device-status');
            const statusText = statusElement?.querySelector('.status-text');
            const deviceType = card.dataset.type;

            if (statusElement) {
                statusElement.dataset.temperature = temperature;
            }

            if (statusText) {
                const isOn = statusElement.classList.contains('on');
                if (deviceType === 'temp-sensor' && isOn) {
                    statusText.textContent = `温度 ${temperature.toFixed(1)}°C`;
                } else if (deviceType === 'ac' && isOn) {
                    const mode = statusElement.dataset.mode || 'cool';
                    const modeText = getModeText(mode);
                    statusText.textContent = `${modeText} ${temperature.toFixed(0)}°C`;
                }
            }

            if (deviceType === 'ac') {
                const detailText = card.querySelector('.device-detail-text');
                if (detailText) {
                    const mode = statusElement.dataset.mode || 'cool';
                    const modeText = getModeText(mode);
                    detailText.textContent = `模式: ${modeText} · ${temperature.toFixed(0)}°C · 风速中`;
                }
            }
        }

        // 更新湿度显示
        function updateHumidityDisplay(card, humidity) {
            const statusElement = card.querySelector('.device-status');
            const statusText = statusElement?.querySelector('.status-text');
            const deviceType = card.dataset.type;

            if (statusElement) {
                statusElement.dataset.humidity = Math.round(humidity);
            }

            if (statusText && deviceType === 'humidity-sensor' && card.querySelector('.device-status')?.classList.contains('on')) {
                statusText.textContent = `湿度 ${Math.round(humidity)}%`;
            }

            if (deviceType === 'lock') {
                updateBatteryDisplay(card, Math.round(humidity));
            }
        }

        // 更新风扇转速显示
        function updateFanSpeedDisplay(card, speed) {
            const statusElement = card.querySelector('.device-status');
            const statusText = statusElement?.querySelector('.status-text');
            const deviceType = card.dataset.type;

            if (statusElement) {
                statusElement.dataset.speed = speed;
            }

            if (statusText && deviceType === 'fan' && card.querySelector('.device-status')?.classList.contains('on')) {
                statusText.textContent = `风速 ${speed}档`;
            }
        }

        // 更新空调模式
        function updateAcModeDisplay(card, mode) {
            const statusElement = card.querySelector('.device-status');
            const statusText = statusElement?.querySelector('.status-text');
            const deviceType = card.dataset.type;

            if (statusElement) {
                statusElement.dataset.mode = mode;
            }

            if (statusText && deviceType === 'ac') {
                const isOn = statusElement.classList.contains('on');
                if (isOn) {
                    const temperature = statusElement.dataset.temperature || '23';
                    const modeText = getModeText(mode);
                    statusText.textContent = `${modeText} ${temperature}°C`;
                }
            }

            const detailText = card.querySelector('.device-detail-text');
            if (detailText) {
                const temperature = statusElement.dataset.temperature || '23';
                const modeText = getModeText(mode);
                detailText.textContent = `模式: ${modeText} · ${temperature}°C · 风速中`;
            }
        }

        // 更新电机方向显示
        function updateMotorDirectionDisplay(card, direction) {
            const statusElement = card.querySelector('.device-status');
            const statusText = statusElement?.querySelector('.status-text');
            const deviceType = card.dataset.type;

            if (statusElement) {
                statusElement.dataset.direction = direction;
            }

            if (statusText && deviceType === 'motor' && card.querySelector('.device-status')?.classList.contains('on')) {
                if (direction === 'forward') {
                    statusText.textContent = '正转';
                } else if (direction === 'reverse') {
                    statusText.textContent = '反转';
                } else {
                    statusText.textContent = '停止';
                }
            }
